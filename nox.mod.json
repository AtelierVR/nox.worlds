{
  "type": "mod",
  "id": "nox.worlds",
  "provides": [
    "fr.hactazia.sdk.worlds",
    "worlds"
  ],
  "name": "Worlds",
  "version": "1.0.0",
  "description": "Provides the World API for the game.",
  "license": "GPL-3.0",
  "icon": null,
  "contact": {
    "email": "hactazia@gmail.com",
    "source": "https://github.com/AtelierVR/nox.worlds",
    "website": "https://nox.hactazia.fr/",
    "issues": "https://github.com/AtelierVR/nox.worlds/issues"
  },
  "authors": [
    {
      "name": "Hactazia",
      "email": "hactazia@gmail.com",
      "website": "https://hactazia.fr/"
    }
  ],
  "relations": [
    {
      "id": "ui",
      "type": "depends",
      "version": ">=1.0.0",
      "register": "git+https://github.com/AtelierVR/nox.ui.git"
    },
    {
      "id": "network",
      "type": "depends",
      "version": ">=1.0.0",
      "register": "git+https://github.com/AtelierVR/nox.network.git"
    },
    {
      "id": "search",
      "type": "depends",
      "version": ">=1.0.0",
      "register": "git+https://github.com/AtelierVR/nox.search.git"
    },
    {
      "id": "users",
      "type": "depends",
      "version": ">=1.0.0",
      "register": "git+https://github.com/AtelierVR/nox.users.git"
    },
    {
      "id": "instances",
      "type": "depends",
      "version": ">=1.0.0",
      "register": "git+https://github.com/AtelierVR/nox.instances.git"
    },
    {
      "id": "com.unity.scriptablebuildpipeline",
      "type": "depends",
      "version": ">=2.1.0",
      "register": "upm+com.unity.scriptablebuildpipeline@2.1.0"
    }
  ],
  "constraints": [
    {
      "type": "after",
      "id": "network"
    },
    {
      "type": "after",
      "id": "search"
    }
  ],
  "entrypoints": {
    "main": [
      "Nox.Worlds.Runtime.Main"
    ],
    "editor": [
      "Nox.Worlds.Runtime.Editor.Editor",
      "Nox.Worlds.Runtime.Editor.BuilderPanel",
      "Nox.Worlds.Runtime.Editor.PublisherPanel"
    ],
    "client": [
      "Nox.Worlds.Runtime.Clients.Client"
    ]
  }
}